// DeepSeek AI Chat

fun main() {
    println("=== DeepSeek AI Chat ===")
    println("Type 'quit' to exit\n")

    var msgs = ""
    var running = true
    for running {
        print("You: ")
        val input = unwrap_or(read_line(), "quit")
        running = input != "quit"
        msgs = when running { chatTurn(input, msgs) else msgs }
    }
    println("Goodbye!")
}

fun chatTurn(input: String, msgs: String): String = {
    val withUser = addMsg(msgs, "user", input)
    val reply = sendMsg(withUser)
    println("AI: " + reply)
    addMsg(withUser, "assistant", reply)
}

fun addMsg(msgs: String, role: String, content: String): String = {
    val msg = "{\"role\":\"" + role + "\",\"content\":\"" + escape(content) + "\"}"
    when msgs == "" { msg else msgs + "," + msg }
}

fun escape(s: String): String =
    replace(replace(replace(replace(replace(
        s, "\\", "\\\\"), "\"", "\\\""), "\n", "\\n"), "\r", "\\r"), "\t", "\\t")

fun sendMsg(msgs: String): String {
    val body = "{\"model\":\"deepseek-chat\",\"messages\":[" + msgs + "]}"
    val headers = "Authorization: Bearer sk-83dcfb84f4e945df9dadf73257781119\nContent-Type: application/json"
    val resp = httpRequest("POST", "https://api.deepseek.com/chat/completions", headers, body)
    extractContent(resp)
}

// Extract content from JSON without using index_of/unwrap (has known bugs)
fun extractContent(raw: String): String {
    val keyStart = findStr(raw, 0, "\"content\":\"")
    val contentStart = keyStart + len("\"content\":\"")
    val end = when keyStart >= 0 { findEndQuote(raw, contentStart) else -1 }
    when keyStart >= 0 { when end >= 0 { substring(raw, contentStart, end - contentStart) else raw } else raw }
}

// Find pattern in s starting from startIndex, return index or -1
fun findStr(s: String, startIndex: Int, pattern: String): Int {
    val patLen = len(pattern)
    val sLen = len(s)
    var i = startIndex
    var found = -1
    for i + patLen <= sLen and found == -1 {
        when substring(s, i, patLen) == pattern { found = i else {} }
        i = i + 1
    }
    found
}

fun findEndQuote(s: String, from: Int): Int {
    var i = from
    var found = -1
    for i < len(s) and found == -1 {
        val ch = substring(s, i, 1)
        when ch == "\\" { i = i + 1 else when ch == "\"" { found = i else {} } }
        i = i + 1
    }
    found
}
