## 二十一、完整示例

### 示例 1：FizzBuzz

```kotlin
fun fizzbuzz(n: Int): String {
    return when (n % 3, n % 5) {
        (0, 0) -> "FizzBuzz"
        (0, _) -> "Fizz"
        (_, 0) -> "Buzz"
        else -> n.to_string()
    }
}

fun main() {
    for i in 1..100 {
        println(fizzbuzz(i))
    }
}
```

### 示例 2：枚举定义与扩展

```kotlin
enum Shape {
    Circle(r: Float)
    Rectangle(w: Float, h: Float)
    Square(s: Float)
}

extension Shape {
    fun area(): Float {
        return when it {
            Circle(r) -> pi * r * r
            Rectangle(w, h) -> w * h
            Square(s) -> s * s
        }
    }

    fun perimeter(): Float {
        return when it {
            Circle(r) -> 2.0 * pi * r
            Rectangle(w, h) -> 2.0 * (w + h)
            Square(s) -> 4.0 * s
        }
    }

    fun is_round(): Bool {
        return when it {
            Circle(_) -> true
            else -> false
        }
    }
}

val shapes = [Circle(5.0), Rectangle(3.0, 4.0), Square(2.0)]
for shape in shapes {
    println("Area: " + shape.area().to_string() +
            ", Round: " + shape.is_round().to_string())
}
```

### 示例 3：数据转换（带错误处理）

```kotlin
type Person = {name: String, age: Int}

enum ValidationError {
    InvalidAge
    NameTooShort
}

fun validate_user(user: Person): Result<Person, ValidationError> {
    return when {
        user.age < 0 || user.age > 150 -> Err(InvalidAge)
        user.name.len() < 2 -> Err(NameTooShort)
        else -> Ok(user)
    }
}

fun format_name(user: Person): String {
    return user.name + " (" + user.age.to_string() + ")"
}

val users = [
    {name = "张三", age = 25},
    {name = "李", age = 200},
    {name = "王五", age = 30},
]

val valid_adult_names = users
    .filter { it.age >= 18 }
    .map(::validate_user)
    .filter { when it { Ok(_) -> true else -> false } }
    .map { when it { Ok(u) -> format_name(u) else -> "" } }
    .filter { it != "" }

for name in valid_adult_names {
    println(name)
}
```

### 示例 4：递归（依赖 TCO）

```kotlin
// 尾递归求和，TCO 保证不爆栈
fun sum(n: Int, acc: Int): Int {
    return when n == 0 then acc else sum(n - 1, acc + n)
}

val total = sum(1_000_000, 0)
println(total)    // 500000500000
```

### 示例 5：链式调用

```kotlin
// 普通链式
val result = [1, 2, 3, 4, 5]
    .filter { it % 2 == 0 }
    .map { it * it }
    .fold(0) { acc, x -> acc + x }

// 安全调用链式（错误传播）
val safe_result = parse_int("123")
    ?.map { it * 2 }
    ?.to_string()
    ?.or_else("default")
```

### 示例 6：高阶函数

```kotlin
// 函数作为参数
fun apply_twice(f: (Int) -> Int, x: Int): Int {
    return f(f(x))
}

val result = apply_twice({ it * 2 }, 5)   // 20

// 函数作为返回值
fun make_counter(): () -> Int {
    var count = 0
    return { count = count + 1; count }
}

val counter = make_counter()
counter()   // 1
counter()   // 2
counter()   // 3
```

### 示例 7：for 表达式

```kotlin
// 基本映射
val squares = for x in [1, 2, 3, 4, 5] { x * x }
// → [1, 4, 9, 16, 25]

// 带过滤
val evens = for x in [1, 2, 3, 4, 5] {
    when x % 2 == 0 then x * x else continue
}
// → [4, 16]

// 多源（笛卡尔积）
val pairs = for x in [1, 2], y in [3, 4] { (x, y) }
// → [(1, 3), (1, 4), (2, 3), (2, 4)]

// 等价写法（链式调用）
val same_list = [1, 2, 3, 4, 5].map { x -> x * x }
```

### 示例 8：Option 使用

```kotlin
fun find_user(id: Int): Option<User> {
    return when users.contains_key(id) then Some(users[id]) else None
}

// when 匹配式
val user_name = when find_user(123) {
    Some(u) -> u.name
    None -> "unknown"
}

// 安全调用式
val city = find_user(123)
    ?.address
    ?.city
    ?.or_else("no city")
```

### 示例 9：extension 扩展标准库

```kotlin
extension List<Int> {
    fun sum(): Int {
        return it.fold(0) { acc, x -> acc + x }
    }

    fun average(): Float {
        return it.sum().to_float() / it.len().to_float()
    }

    fun median(): Float {
        val sorted = it.sorted()
        val mid = sorted.len() / 2
        return when sorted.len() % 2 == 0 then
            (sorted[mid - 1] + sorted[mid]).to_float() / 2.0
        else
            sorted[mid].to_float()
    }
}

val numbers = [1, 2, 3, 4, 5, 6]
println(numbers.sum())      // 21
println(numbers.average())  // 3.5
println(numbers.median())   // 3.5
```

### 示例 10：树结构遍历

```kotlin
enum Tree<T> {
    Leaf(T)
    Node(left: Tree<T>, right: Tree<T>)
}

fun <T> depth(t: Tree<T>): Int {
    return when t {
        Leaf(_) -> 1
        Node(l, r) -> 1 + max(depth(l), depth(r))
    }
}

fun <T> flatten(t: Tree<T>): List<T> {
    return when t {
        Leaf(v) -> [v]
        Node(l, r) -> flatten(l) + flatten(r)
    }
}

val tree = Node(
    Node(Leaf(1), Leaf(2)),
    Leaf(3)
)

println(depth(tree))      // 3
println(flatten(tree))    // [1, 2, 3]
```

### 示例 11：JSON 解析器骨架

```kotlin
enum JsonValue {
    Null
    Bool(b: Bool)
    Num(n: Float)
    Str(s: String)
    Arr(items: List<JsonValue>)
    Obj(fields: Map<String, JsonValue>)
}

extension JsonValue {
    fun to_string(): String {
        return when it {
            Null -> "null"
            Bool(b) -> when b then "true" else "false"
            Num(n) -> n.to_string()
            Str(s) -> "\"" + s + "\""
            Arr(items) -> "[" + items.map(JsonValue::to_string).join(", ") + "]"
            Obj(fields) -> "{" +
                fields.entries()
                    .map { (k, v) -> "\"" + k + "\": " + v.to_string() }
                    .join(", ") +
                "}"
        }
    }

    fun get(path: List<String>): Option<JsonValue> {
        return when path {
            [] -> Some(it)
            [key, ...rest] -> when it {
                Obj(fields) -> fields.get(key).flat_map { it.get(rest) }
                else -> None
            }
        }
    }
}
```

### 示例 12：模块系统实战

```kotlin
// ---- math.atom ----
module math {
    export fun add(x: Int, y: Int): Int = x + y
    export fun sub(x: Int, y: Int): Int = x - y

    fun helper(): Int = 0   // 模块私有
}

// ---- main.atom ----
import math.{add}

fun main() {
    val result = add(1, 2)
    println(result)
}
```

### 示例 13：协程并发

```kotlin
// 模拟 API 调用
fun fetchUser(id: Int): User {
    delay(100)
    return {name = "User$id", age = 20 + id}
}

fun fetchPosts(id: Int): List<Post> {
    delay(200)
    return [{title = "Post 1"}, {title = "Post 2"}]
}

fun fetchFriends(id: Int): List<User> {
    delay(150)
    return [{name = "Friend1", age = 22}]
}

// 并发获取——总耗时 ≈ 100ms（而非 300ms）
fun loadAllUsers(): List<User> {
    return coroutineScope {
        launch { fetchUser(1) }
        launch { fetchUser(2) }
        launch { fetchUser(3) }
    }
}

// 组合不同类型结果——用索引 + as 转型
type Profile = {user: User, posts: List<Post>, friends: List<User>}

fun loadProfile(id: Int): Profile {
    val results = coroutineScope {
        launch { fetchUser(id) }
        launch { fetchPosts(id) }
        launch { fetchFriends(id) }
    }
    return {
        user = results[0] as User,
        posts = results[1] as List<Post>,
        friends = results[2] as List<User>
    }
}

// Stream 管道——读取 → 解析 → 输出
fun processData() {
    coroutineScope {
        val raw = stream<String>()
        val parsed = stream<Int>()

        launch {
            for line in readLines("data.txt") {
                raw.send(line)
            }
            raw.close()
        }

        launch {
            for line in raw {
                val num? = parse_int(line)
                parsed.send(num)
            }
            parsed.close()
        }

        launch {
            for num in parsed {
                println(num)
            }
        }
    }
}

// 超时控制
fun safeLoad(ids: List<Int>): Result<List<User>, TimeoutError> {
    return withTimeout(5000) {
        coroutineScope {
            for id in ids {
                launch { fetchUser(id) }
            }
        }
    }
}
```

