{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Atomic",
  "scopeName": "source.atomic",
  "fileTypes": [".at", ".atom"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#chars"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.atomic",
          "match": "//.*$"
        },
        {
          "name": "comment.block.documentation.atomic",
          "begin": "/\\*\\*(?!/)",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        },
        {
          "name": "comment.block.atomic",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.atomic",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "include": "#string_interpolation"
            },
            {
              "name": "constant.character.escape.atomic",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.atomic",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "include": "#string_interpolation"
            },
            {
              "name": "constant.character.escape.atomic",
              "match": "\\\\[ntr\\\\\"0$]"
            },
            {
              "name": "constant.character.escape.unicode.atomic",
              "match": "\\\\u\\{[0-9a-fA-F]+\\}"
            }
          ]
        }
      ]
    },
    "string_interpolation": {
      "name": "meta.interpolation.atomic",
      "begin": "\\$\\{",
      "end": "\\}",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.atomic",
      "match": "'(?:[^'\\\\]|\\\\.)'"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.atomic",
          "match": "\\b\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)\\b"
        },
        {
          "name": "constant.numeric.float.atomic",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.hex.atomic",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.atomic",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.atomic",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "name": "constant.numeric.integer.atomic",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.atomic",
          "match": "\\b(when|else|for|in|break|continue|return)\\b"
        },
        {
          "name": "keyword.declaration.atomic",
          "match": "\\b(val|var|fun|enum|type|const|lazy)\\b"
        },
        {
          "name": "keyword.other.atomic",
          "match": "\\b(import|module|export|extension|as|copy|unsafe|external|is)\\b"
        },
        {
          "name": "keyword.operator.logical.atomic",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.boolean.atomic",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "storage.type.atomic",
          "match": "\\b(Task)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.atomic",
          "match": "\\b(Int|Float|Bool|String|Char|Unit)\\b"
        },
        {
          "name": "support.type.collection.atomic",
          "match": "\\b(List|Set|Map|LazyList|Stream|Range)\\b"
        },
        {
          "name": "support.type.other.atomic",
          "match": "\\b(Option|Result|CString|Ptr|FileHandle|Some|None|Ok|Err)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.atomic",
          "begin": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<[^>]*>)?\\s*\\(",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.atomic" },
            "2": { "name": "entity.name.function.atomic" }
          },
          "end": "\\)",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "meta.function-call.atomic",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.atomic" }
          }
        }
      ]
    },
    "constants": {
      "name": "variable.other.constant.atomic",
      "match": "\\b([A-Z][A-Z0-9_]*)\\b"
    },
    "variables": {
      "name": "variable.other.readwrite.atomic",
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.atomic",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.comparison.atomic",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.arrow.atomic",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.range.atomic",
          "match": "\\.\\.<|\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.atomic",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.atomic",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.bitwise.atomic",
          "match": "<<|>>"
        },
        {
          "name": "keyword.operator.arithmetic.atomic",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.atomic",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.bitwise.atomic",
          "match": "[&|^~]"
        },
        {
          "name": "keyword.operator.comparison.atomic",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.assignment.atomic",
          "match": "="
        },
        {
          "name": "keyword.operator.atomic",
          "match": "[!?:;,.]"
        },
        {
          "name": "punctuation.definition.bracket.atomic",
          "match": "[\\[\\]{}()]"
        }
      ]
    }
  }
}
